# Strands Visual Builder - Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=https://your-cloudfront-domain.cloudfront.net

# AWS Region
VITE_AWS_REGION=us-west-2

# Cognito Authentication
VITE_COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=your-client-id-here

# Environment
VITE_NODE_ENV=development
VITE_DEBUG=false
